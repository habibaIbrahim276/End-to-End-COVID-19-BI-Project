                        <arrayElement
                          dataType="System.String"><![CDATA[using System;
using System.Data;
using Microsoft.SqlServer.Dts.Pipeline.Wrapper;
using Microsoft.SqlServer.Dts.Runtime.Wrapper;

[Microsoft.SqlServer.Dts.Pipeline.SSISScriptComponentEntryPointAttribute]
public class ScriptMain : UserComponent
{
    public override void PreExecute()
    {
        base.PreExecute();
    }

    public override void PostExecute()
    {
        base.PostExecute();
    }

    public override void Input0_ProcessInputRow(Input0Buffer Row)
    {
        // create new column (location_type)
        if (Row.isocode == "OWID_WRL" || Row.isocode == "OWID_KOS")
        {
            Row.locationtype = "World";
        }
        else if (Row.isocode_IsNull || Row.isocode == " " || Row.isocode == "")
        {
            Row.locationtype = "International";
        }
        else
        {
            Row.locationtype = "Country";
        }

        // filling nulls on iso_code, continent, location columns 
        if (Row.isocode_IsNull || Row.isocode == "" || Row.isocode == " ")
        {
            Row.isocode = "Unknown"; 
        }

        if (Row.continent_IsNull || Row.continent == "" || Row.continent == " ")
        {
            Row.continent = "Unknown";
        }
        if (Row.location_IsNull || Row.location == "" || Row.location == " ")
        {
            Row.location = "Unknown";
        }

        // cleaning total_cases, new_cases columns: 
        if (Row.totalcases_IsNull || Row.totalcases == "" || Row.totalcases == " ")
        {
            Row.totalcases = null;   
        }
        if (Row.newcases_IsNull || Row.newcases == "" || Row.newcases == " ")
        {
            Row.newcases = null;
        }
        if(Row.totaldeaths_IsNull || Row.totaldeaths == "" || Row.totaldeaths == " ")
        {
            Row.totaldeaths = null;
        }
        if(Row.newdeaths_IsNull || Row.newdeaths == "" || Row.newdeaths == " ")
        {
            Row.newdeaths = null;
        }
        if(Row.newdeathssmoothed_IsNull || Row.newdeathssmoothed == "" || Row.newdeathssmoothed == " ")
        {
            Row.newdeathssmoothed = null;
        }

    }

    
    }]]></arrayElement>
